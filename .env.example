# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# PostgreSQL password (choose your own)
DB_PASSWORD=

# Derived from DB_PASSWORD — update both if you change it
DATABASE_URL=postgresql+psycopg2://barhopping:changeme@db/barhopping

# Redis URL (default works with docker-compose)
REDIS_URL=redis://redis:6379

# OpenRouter catalogue PDF extraction (worker only; disabled by default)
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_PDF_ENGINE=mistral-ocr
OPENROUTER_PDF_PAGES_PER_CHUNK=8
OPENROUTER_PDF_CHUNK_OVERLAP=0
OPENROUTER_MAX_TOKENS=32768
OPENROUTER_MAX_CONCURRENCY=3

# TopDog login for worker jobs and live integration tests (tests/test_topdog_integration.py)
TOPDOG_USER=
TOPDOG_PW=
